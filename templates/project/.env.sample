# ─── Application ────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── Database ───────────────────────────────────────────────
MONGODB_URI={{MONGODB_URI}}

# ─── Authentication ─────────────────────────────────────────
# REQUIRED in production — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# JWT_EXPIRY=900  # seconds (default: 15 minutes)
REFRESH_TOKEN_SECRET=
# REFRESH_TOKEN_EXPIRY=604800  # seconds (default: 7 days)

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in development)
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# ─── Logging ────────────────────────────────────────────────
# LOG_LEVEL=info  # trace, debug, info, warn, error, fatal

# ─── AWS S3 / MinIO ────────────────────────────────────────
# ACCESS_KEY_ID=
# SECRET_ACCESS_KEY=
# BUCKET_NAME=
# REGION=ap-south-1
# S3_ENDPOINT=  # For MinIO or S3-compatible services